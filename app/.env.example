# Moments API (backend/src/server.ts) — defaults to http://localhost:8787 if unset.
VITE_MOMENTS_API_URL=http://localhost:8787

# Devnet RPC endpoint used for pack payment + confirmation. Left unset, this falls back to
# Solana's public devnet RPC, which is shared by every developer testing on devnet worldwide
# and is rate-limited/slow to confirm under load -- that's what shows up as pack payment
# hanging on "Approved -- confirming on devnet...". Get a free devnet endpoint from Helius,
# QuickNode, Alchemy, or Triton and set it here to fix that.
VITE_SOLANA_RPC_URL=